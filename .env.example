TWITCH_CHANNEL=your_channel_name

# Recommended for stable Twitch chat access.
# Generate a user token with chat:read scope and paste it with or without oauth: prefix.
TWITCH_USERNAME=your_bot_or_account_name
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Local web server used by OBS Browser Source.
PORT=3000

# TTS/message filters.
READ_USERNAMES=true
TTS_COMMAND=!tts
MAX_MESSAGE_LENGTH=220
MIN_SECONDS_BETWEEN_MESSAGES=1.2
TTS_ENGINE=browser
OBS_ROUTE=/obs
PIPER_VOICE_ID=ru_RU-dmitri-medium
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
SILERO_SPEAKER=xenia
SILERO_PYTHON_PATH=
SILERO_SCRIPT_PATH=
SILERO_MODEL_CACHE_DIR=

# Comma-separated lower-case usernames to ignore.
IGNORED_USERS=nightbot,streamelements
